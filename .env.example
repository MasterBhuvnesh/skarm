# Copy to .env.local and fill in. Get Clerk/Convex values from their dashboards.

# Public site origin — used for SEO metadata, OG image, robots, sitemap.
# Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=

# Clerk — https://dashboard.clerk.com (API keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=

# Clerk auth routes (defaults work as-is)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/onboarding
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# Convex — set by `npx convex dev`
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Clerk webhook signing secret — Clerk dashboard → Webhooks (Convex HTTP endpoint)
CLERK_WEBHOOK_SECRET=

# NVIDIA NIM API key (AI agent) — https://build.nvidia.com
NVIDIA_API_KEY=
